---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

const cases = await getCollection('cases');

const rendered = await Promise.all(
  cases.map(async (c) => {
    const { Content } = await render(c);
    return { ...c, Content };
  })
);

const statusLabel: Record<string, string> = {
  active: 'Active',
  wip: 'In development',
  archived: 'Archived',
};

const statusClass: Record<string, string> = {
  active: 'status-badge--active',
  wip: 'status-badge--wip',
  archived: 'status-badge--archived',
};
---

<Base title="Projects" description="Side projects — things I'm building, testing, or figuring out outside the peer-reviewed literature." currentPage="cases">
  <!-- Page header -->
  <section class="page-header">
    <div class="container">
      <p class="label label--accent animate-in">Projects</p>
      <h1 class="animate-in animate-in--delay-1">Side projects</h1>
      <p class="page-intro animate-in animate-in--delay-2">
        Things I'm building, testing, or figuring out outside the peer-reviewed literature.
      </p>
    </div>
  </section>

  <section class="section--toned">
    <div class="container container--narrow">
      <div class="showcase-list">
        {rendered.map((c, i) => (
          <article class={`showcase-card card animate-in animate-in--delay-${Math.min(i + 1, 4)}`}>
            <header class="showcase-card__header">
              <div class="showcase-card__title-row">
                <h2 class="showcase-card__title">{c.data.title}</h2>
                <span class={`status-badge ${statusClass[c.data.status]}`}>
                  {statusLabel[c.data.status]}
                </span>
              </div>
              <p class="showcase-card__description">{c.data.description}</p>
            </header>

            <div class="prose showcase-card__body">
              <c.Content />
            </div>

            <footer class="showcase-card__footer">
              <div class="showcase-card__tags">
                {c.data.tags.map((tag: string) => (
                  <span class="chip">{tag}</span>
                ))}
              </div>
              {c.data.url && (
                <a href={c.data.url} target="_blank" rel="noopener" class="btn btn--primary">
                  Visit project
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M7 17L17 7" /><path d="M7 7h10v10" />
                  </svg>
                </a>
              )}
            </footer>
          </article>
        ))}
      </div>

      {cases.length === 0 && (
        <div class="empty-state">
          <div class="empty-state__icon" aria-hidden="true">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="8" y="12" width="32" height="28" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/>
              <path d="M16 22h16M16 29h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <path d="M28 8v8M20 8v8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <h3 class="empty-state__title">Projects coming soon</h3>
          <p class="empty-state__desc">
            I'm preparing writeups of side projects — digital planning workflows,
            3D printing experiments, and technique explorations from practice.
          </p>
        </div>
      )}
    </div>
  </section>
</Base>

<style>
  .page-header {
    padding: var(--space-20) 0 var(--space-8);
  }

  .page-header .label {
    margin-bottom: var(--space-4);
  }

  .page-header h1 {
    margin-bottom: var(--space-4);
  }

  .page-intro {
    font-size: 1.0625rem;
    color: var(--on-surface-variant);
    line-height: 1.7;
    max-width: 55ch;
  }

  /* Showcase layout */
  .showcase-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  .showcase-card {
    padding: var(--space-10);
  }

  .showcase-card__header {
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--ghost-border);
  }

  .showcase-card__title-row {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-3);
    flex-wrap: wrap;
  }

  .showcase-card__title {
    font-family: var(--font-headline);
    font-size: clamp(1.5rem, 3vw, 2rem);
    line-height: 1.2;
    color: var(--on-surface);
    margin: 0;
  }

  .showcase-card__description {
    font-size: 0.9375rem;
    color: var(--on-surface-variant);
    line-height: 1.7;
    max-width: 65ch;
    margin: 0;
  }

  /* Status badges */
  .status-badge {
    display: inline-block;
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: var(--space-1) var(--space-3);
    border-radius: 0.25rem;
    flex-shrink: 0;
  }

  .status-badge--active {
    background: var(--primary-fixed);
    color: var(--primary-dark);
  }

  .status-badge--wip {
    background: #fff3cd;
    color: #856404;
  }

  .status-badge--archived {
    background: var(--surface-container-high);
    color: var(--on-surface-variant);
  }

  /* Card body (rendered markdown) */
  .showcase-card__body {
    margin-bottom: var(--space-8);
  }

  /* Footer with tags + CTA */
  .showcase-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding-top: var(--space-6);
    border-top: 1px solid var(--ghost-border);
    flex-wrap: wrap;
  }

  .showcase-card__tags {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  /* Empty state */
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--space-24) var(--space-8);
    max-width: 36rem;
    margin: 0 auto;
    gap: var(--space-4);
  }

  .empty-state__icon {
    color: var(--outline-variant);
    margin-bottom: var(--space-2);
  }

  .empty-state__title {
    font-family: var(--font-headline);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--on-surface);
    margin-bottom: 0;
  }

  .empty-state__desc {
    font-size: 0.9375rem;
    color: var(--on-surface-variant);
    line-height: 1.7;
    max-width: 40ch;
    font-style: normal;
    margin-bottom: var(--space-2);
  }

  @media (max-width: 768px) {
    .page-header {
      padding: var(--space-12) 0 var(--space-4);
    }

    .showcase-card {
      padding: var(--space-6);
    }

    .showcase-card__footer {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
