---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const cases = (await getCollection('cases'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-AU', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title="Projects" description="Side projects — things I'm building, testing, or figuring out outside the peer-reviewed literature." currentPage="cases">
  <!-- Page header -->
  <section class="page-header">
    <div class="container">
      <p class="label label--accent animate-in">Projects</p>
      <h1 class="animate-in animate-in--delay-1">Side projects</h1>
      <p class="page-intro animate-in animate-in--delay-2">
        Things I'm building, testing, or figuring out outside the peer-reviewed literature.
      </p>
    </div>
  </section>

  <section class="section--toned">
    <div class="container">
      <div class="review-list review-list--grid">
        {cases.map((c, i) => (
          <a href={`/cases/${c.id}`} class={`review-card animate-in animate-in--delay-${Math.min(i + 1, 4)}`}>
            <article class="card">
              <p class="review-card__date">{formatDate(c.data.pubDate)}</p>
              <h3 class="review-card__title">{c.data.title}</h3>
              <p class="review-card__description">{c.data.description}</p>
              <div class="review-card__tags">
                {c.data.tags.map((tag: string) => (
                  <span class="chip">{tag}</span>
                ))}
              </div>
            </article>
          </a>
        ))}
      </div>

      {cases.length === 0 && (
        <div class="empty-state">
          <div class="empty-state__icon" aria-hidden="true">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="8" y="12" width="32" height="28" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/>
              <path d="M16 22h16M16 29h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <path d="M28 8v8M20 8v8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <h3 class="empty-state__title">Projects coming soon</h3>
          <p class="empty-state__desc">
            I'm preparing writeups of side projects — digital planning workflows,
            3D printing experiments, and technique explorations from practice.
            Follow along on <a href="https://samuelrosehill.substack.com" target="_blank" rel="noopener">Substack</a> to be notified when new projects are published.
          </p>
          <a href="/reviews" class="btn btn--ghost">Browse the journal instead &rarr;</a>
        </div>
      )}
    </div>
  </section>
</Base>

<style>
  .page-header {
    padding: var(--space-20) 0 var(--space-8);
  }

  .page-header .label {
    margin-bottom: var(--space-4);
  }

  .page-header h1 {
    margin-bottom: var(--space-4);
  }

  .page-intro {
    font-size: 1.0625rem;
    color: var(--on-surface-variant);
    line-height: 1.7;
    max-width: 55ch;
  }

  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--space-24) var(--space-8);
    max-width: 36rem;
    margin: 0 auto;
    gap: var(--space-4);
  }

  .empty-state__icon {
    color: var(--outline-variant);
    margin-bottom: var(--space-2);
  }

  .empty-state__title {
    font-family: var(--font-headline);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--on-surface);
    margin-bottom: 0;
  }

  .empty-state__desc {
    font-size: 0.9375rem;
    color: var(--on-surface-variant);
    line-height: 1.7;
    max-width: 40ch;
    font-style: normal;
    margin-bottom: var(--space-2);
  }

  @media (max-width: 768px) {
    .page-header {
      padding: var(--space-12) 0 var(--space-4);
    }
  }
</style>
