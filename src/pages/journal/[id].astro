---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const reviews = await getCollection('reviews');
  return reviews.map((review) => ({
    params: { id: review.id },
    props: { review, allReviews: reviews },
  }));
}

const { review, allReviews } = Astro.props;
const { Content } = await render(review);

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-AU', { year: 'numeric', month: 'long', day: 'numeric' });

// Reading time estimate
const wordCount = review.body ? review.body.split(/\s+/).filter(Boolean).length : 500;
const readingMinutes = Math.max(1, Math.ceil(wordCount / 200));

// Related articles: same tag overlap, excluding current, max 3
const relatedReviews = allReviews
  .filter((r) => r.id !== review.id)
  .map((r) => ({
    review: r,
    overlap: r.data.tags.filter((t: string) => review.data.tags.includes(t)).length,
  }))
  .sort((a, b) => b.overlap - a.overlap || b.review.data.pubDate.valueOf() - a.review.data.pubDate.valueOf())
  .slice(0, 3)
  .map((r) => r.review);
---

<Base title={review.data.title} description={review.data.description} ogImage={`/images/reviews/${review.id}.png`}>
  <!-- Article schema -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": review.data.title,
    "description": review.data.description,
    "datePublished": review.data.pubDate.toISOString().split('T')[0],
    "dateModified": review.data.pubDate.toISOString().split('T')[0],
    "image": `https://samrosehill.com/images/reviews/${review.id}.png`,
    "author": {
      "@type": "Person",
      "name": "Dr. Samuel Rosehill",
      "url": "https://samrosehill.com/about",
      "jobTitle": "Dentist"
    },
    "publisher": {
      "@type": "Person",
      "name": "Dr. Samuel Rosehill",
      "url": "https://samrosehill.com"
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": `https://samrosehill.com/journal/${review.id}`
    },
    "articleSection": "Dental Research Reviews",
    "keywords": review.data.tags.join(", "),
    "timeRequired": `PT${readingMinutes}M`,
    "about": {
      "@type": "ScholarlyArticle",
      "name": review.data.paperTitle,
      "author": review.data.paperAuthors,
      "isPartOf": {
        "@type": "Periodical",
        "name": review.data.paperJournal
      },
      "datePublished": String(review.data.paperYear)
    },
    "speakable": {
      "@type": "SpeakableSpecification",
      "cssSelector": [".article__desc", ".clinical-relevance__text"]
    }
  })} />

  <!-- Breadcrumb schema -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samrosehill.com" },
      { "@type": "ListItem", "position": 2, "name": "Journal", "item": "https://samrosehill.com/journal" },
      { "@type": "ListItem", "position": 3, "name": review.data.title }
    ]
  })} />

  <article class="article">
    <div class="container container--narrow">
      <!-- Header -->
      <header class="article__header animate-in">
        <a href="/journal" class="back-link">&larr; Back to journal</a>
        <div class="article__meta">
          <p class="label label--accent">{formatDate(review.data.pubDate)}</p>
          <p class="article__reading-time">{readingMinutes} min read</p>
        </div>
        <h1>{review.data.title}</h1>
        <p class="article__desc">{review.data.description}</p>
        <div class="article__tags">
          {review.data.tags.map((tag: string) => (
            <span class="chip">{tag}</span>
          ))}
        </div>
      </header>

      <!-- Paper reference -->
      <div class="paper-ref animate-in animate-in--delay-1">
        <p class="paper-ref__label">Source Paper</p>
        <p class="paper-ref__title">{review.data.paperTitle}</p>
        <p class="paper-ref__meta">
          {review.data.paperAuthors} &middot; <em>{review.data.paperJournal}</em> ({review.data.paperYear})
        </p>
      </div>

      <hr class="divider" />

      <!-- Review body -->
      <div class="prose animate-in animate-in--delay-2">
        <Content />
      </div>

      <!-- Clinical relevance callout -->
      {review.data.clinicalRelevance && (
        <div class="clinical-relevance animate-in animate-in--delay-3">
          <p class="clinical-relevance__label">Clinical Relevance</p>
          <p class="clinical-relevance__text">{review.data.clinicalRelevance}</p>
        </div>
      )}

      <!-- Conflict of interest disclosure -->
      <div class="coi-disclosure">
        <p class="coi-disclosure__text">
          <strong>Disclosure:</strong> The author has no financial conflicts of interest related to the products or topics discussed in this review. This is an independent summary prepared for educational purposes.
        </p>
      </div>

      <!-- Substack CTA -->
      <div class="substack-cta animate-in animate-in--delay-3">
        <p class="substack-cta__label">Continue the conversation</p>
        <p class="substack-cta__desc">This review is also published on Substack, where you can leave comments and join the discussion.</p>
        <a href={review.data.substackUrl || 'https://samuelrosehill.substack.com'} target="_blank" rel="noopener" class="btn btn--primary">
          Read on Substack &rarr;
        </a>
      </div>

      <!-- Related articles -->
      {relatedReviews.length > 0 && (
        <div class="related-articles">
          <p class="label label--accent related-articles__label">More from the archive</p>
          <div class="related-articles__grid">
            {relatedReviews.map((r) => (
              <a href={`/journal/${r.id}`} class="related-card">
                <span class="related-card__date">{formatDate(r.data.pubDate)}</span>
                <span class="related-card__title">{r.data.title}</span>
                <span class="related-card__read">Read &rarr;</span>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- End nav -->
      <div class="article__end">
        <a href="/journal" class="btn btn--ghost">&larr; Back to journal</a>
      </div>
    </div>
  </article>
</Base>

<style>
  .article {
    padding: var(--space-12) 0 var(--space-24);
  }

  .article__header {
    margin-bottom: var(--space-10);
  }

  .article__meta {
    margin-bottom: var(--space-4);
  }

  .article__header h1 {
    font-size: clamp(1.875rem, 4.5vw, 2.5rem);
    max-width: 22ch;
    margin-bottom: var(--space-4);
    line-height: 1.15;
  }

  .article__desc {
    font-size: 1.0625rem;
    color: var(--on-surface-variant);
    line-height: 1.7;
    max-width: 55ch;
    margin-bottom: var(--space-6);
  }

  .article__tags {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .article__end {
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: 1px solid var(--ghost-border-strong);
  }

  /* Reading time */
  .article__reading-time {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--on-surface-variant);
    letter-spacing: 0.04em;
    margin-top: var(--space-1);
  }

  /* Conflict of interest disclosure */
  .coi-disclosure {
    margin-top: var(--space-12);
    padding: var(--space-4) var(--space-6);
    background: var(--surface-container-low);
    border-radius: 0.375rem;
    border-left: 2px solid var(--outline-variant);
  }

  .coi-disclosure__text {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--on-surface-variant);
    line-height: 1.65;
    max-width: 100%;
  }

  /* Substack CTA upgrade */
  .substack-cta {
    margin-top: var(--space-12);
    padding: var(--space-8) var(--space-10);
    background: var(--surface-container-low);
    border: 1px solid var(--ghost-border-strong);
    border-radius: 0.5rem;
    border-left: 3px solid var(--primary);
  }

  .substack-cta__label {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--primary-dark);
    margin-bottom: var(--space-2);
  }

  .substack-cta__desc {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--on-surface-variant);
    line-height: 1.65;
    margin-bottom: var(--space-6);
    max-width: 50ch;
  }

  /* Related articles */
  .related-articles {
    margin-top: var(--space-16);
    padding-top: var(--space-10);
    border-top: 1px solid var(--ghost-border-strong);
  }

  .related-articles__label {
    margin-bottom: var(--space-6);
    display: block;
  }

  .related-articles__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--space-4);
  }

  .related-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-6);
    background: var(--surface-container-lowest);
    border: 1px solid var(--ghost-border);
    border-radius: 0.5rem;
    text-decoration: none;
    color: inherit;
    transition: all var(--duration-medium) var(--ease-out);
  }

  .related-card:hover {
    background: var(--surface-container-low);
    box-shadow: var(--shadow-elevated);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .related-card__date {
    font-family: var(--font-body);
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--on-surface-variant);
  }

  .related-card__title {
    font-family: var(--font-headline);
    font-size: 1rem;
    line-height: 1.4;
    color: var(--on-surface);
    flex: 1;
    transition: color var(--duration-fast) ease;
  }

  .related-card:hover .related-card__title {
    color: var(--primary-dark);
  }

  .related-card__read {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--primary-dark);
    letter-spacing: 0.02em;
    margin-top: var(--space-2);
  }
</style>
