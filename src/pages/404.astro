---
import Base from '../layouts/Base.astro';
---

<Base title="Page Not Found" description="The page you were looking for doesn't exist.">
  <section class="error-page">
    <div class="container">
      <div class="error-page__inner animate-in">
        <p class="label label--accent">404</p>
        <h1 class="error-page__title">Page not found</h1>
        <p class="error-page__desc">
          The page you were looking for doesn't exist, or may have been moved.
          Try the journal archive or head back to the homepage.
        </p>
        <div class="error-page__actions">
          <a href="/" class="btn btn--primary">Go home</a>
          <a href="/reviews" class="btn btn--ghost">Browse the archive</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .error-page {
    padding: var(--space-32) 0 var(--space-24);
    min-height: 60vh;
    display: flex;
    align-items: center;
  }

  .error-page__inner {
    max-width: 36rem;
  }

  .error-page__inner .label {
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    margin-bottom: var(--space-4);
    display: block;
  }

  .error-page__title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1.05;
    margin-bottom: var(--space-6);
    letter-spacing: -0.025em;
  }

  .error-page__desc {
    font-size: 1.0625rem;
    color: var(--on-surface-variant);
    line-height: 1.7;
    margin-bottom: var(--space-10);
    max-width: 45ch;
  }

  .error-page__actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  @media (max-width: 480px) {
    .error-page {
      padding: var(--space-20) 0 var(--space-16);
    }

    .error-page__actions {
      flex-direction: column;
    }

    .error-page__actions .btn {
      text-align: center;
      justify-content: center;
    }
  }
</style>
