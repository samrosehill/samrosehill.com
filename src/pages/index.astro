---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const reviews = (await getCollection('reviews'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = reviews[0];
const latest = reviews.slice(1, 4);

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-AU', { year: 'numeric', month: 'long', day: 'numeric' });

const formatTags = (tags: string[]) =>
  tags.slice(0, 3).join(' / ');
---

<Base title="Home" currentPage="home">
  <!-- WebSite schema -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Dr. Samuel Rosehill",
    "url": "https://samrosehill.com",
    "description": "A clinical archive of dental research reviews and case notes by Dr. Samuel Rosehill.",
    "author": {
      "@type": "Person",
      "name": "Dr. Samuel Rosehill",
      "url": "https://samrosehill.com/about"
    }
  })} />

  <!-- Hero — compact byline -->
  <section class="hero animate-in">
    <div class="container">
      <p class="label label--accent">A Clinical Archive</p>
      <p class="hero__byline">
        by Dr. Samuel Rosehill — prosthodontics, digital dentistry, and implantology.
      </p>
    </div>
  </section>

  <!-- Split Folio — teal rail -->
  <section class="folio">
    <div class="container">
      <div class="folio__split">
        <!-- Featured article — teal rail -->
        {featured && (
          <div class="folio__featured animate-in">
            <a href={`/journal/${featured.id}`} class="folio__featured-link">
              <p class="folio__date">{formatDate(featured.data.pubDate)}</p>
              <h2 class="folio__title">{featured.data.title}</h2>
              <p class="folio__desc">{featured.data.description}</p>
              <p class="folio__tags">{formatTags(featured.data.tags)}</p>
              <p class="folio__read">Read review &rarr;</p>
            </a>
          </div>
        )}

        <!-- Sidebar — recent entries -->
        <div class="folio__sidebar">
          {latest.map((review, i) => (
            <a href={`/journal/${review.id}`} class={`folio__sidebar-item animate-in animate-in--delay-${i + 1}`}>
              <p class="folio__sidebar-date">{formatDate(review.data.pubDate)}</p>
              <h3 class="folio__sidebar-title">{review.data.title}</h3>
              <p class="folio__sidebar-snip">{review.data.description.slice(0, 80)}...</p>
            </a>
          ))}
          <a href="/journal" class="folio__archive-link animate-in animate-in--delay-4">Full archive &rarr;</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  /* Hero — compact */
  .hero {
    padding: var(--space-10) 0 var(--space-6);
    border-bottom: 1px solid var(--ghost-border);
  }

  .hero__byline {
    font-family: var(--font-headline);
    font-style: italic;
    font-size: 0.9375rem;
    color: var(--on-surface-variant);
    margin-top: var(--space-2);
  }

  /* Split Folio */
  .folio {
    padding: var(--space-8) 0 var(--space-16);
  }

  .folio__split {
    display: grid;
    grid-template-columns: 7fr 5fr;
    gap: var(--space-8);
  }

  /* Featured — teal rail */
  .folio__featured {
    border-left: 2px solid var(--primary);
    padding-left: var(--space-6);
  }

  .folio__featured-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .folio__featured-link:hover {
    text-decoration: none;
  }

  .folio__date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6875rem;
    color: var(--on-surface-variant);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: var(--space-3);
  }

  .folio__title {
    font-family: var(--font-headline);
    font-size: clamp(1.375rem, 3vw, 1.75rem);
    line-height: 1.22;
    color: var(--on-surface);
    margin-bottom: var(--space-4);
    transition: color var(--duration-fast) ease;
  }

  .folio__featured-link:hover .folio__title {
    color: var(--primary-dark);
  }

  .folio__desc {
    font-size: 0.9375rem;
    color: var(--on-surface-variant);
    line-height: 1.65;
    margin-bottom: var(--space-4);
    max-width: 55ch;
  }

  .folio__tags {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6875rem;
    color: var(--outline);
    margin-bottom: var(--space-4);
  }

  .folio__read {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--primary);
    transition: opacity var(--duration-fast) ease;
  }

  .folio__featured-link:hover .folio__read {
    opacity: 0.75;
  }

  /* Sidebar */
  .folio__sidebar {
    display: flex;
    flex-direction: column;
  }

  .folio__sidebar-item {
    display: block;
    text-decoration: none;
    color: inherit;
    border-left: 1px solid var(--ghost-border);
    padding: var(--space-5) 0 var(--space-6) var(--space-5);
    transition: border-color var(--duration-fast) ease;
  }

  .folio__sidebar-item + .folio__sidebar-item {
    margin-top: var(--space-6);
  }

  .folio__sidebar-item:hover {
    text-decoration: none;
    border-color: var(--primary);
  }

  .folio__sidebar-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.625rem;
    color: var(--outline);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: var(--space-1);
  }

  .folio__sidebar-title {
    font-family: var(--font-headline);
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.3;
    color: var(--on-surface);
    margin-bottom: var(--space-1);
    transition: color var(--duration-fast) ease;
  }

  .folio__sidebar-item:hover .folio__sidebar-title {
    color: var(--primary-dark);
  }

  .folio__sidebar-snip {
    font-size: 0.8125rem;
    color: var(--outline);
    line-height: 1.45;
  }

  .folio__archive-link {
    display: block;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--primary);
    padding: var(--space-4) 0 0 var(--space-5);
    text-decoration: none;
  }

  .folio__archive-link:hover {
    text-decoration: none;
    opacity: 0.75;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero {
      padding: var(--space-8) 0 var(--space-4);
    }

    .folio {
      padding: var(--space-6) 0 var(--space-12);
    }

    .folio__split {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }

    .folio__sidebar {
      border-top: 1px solid var(--ghost-border);
      padding-top: var(--space-6);
    }

    .folio__sidebar-item + .folio__sidebar-item {
      margin-top: var(--space-8);
    }
  }
</style>
