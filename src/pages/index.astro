---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const reviews = (await getCollection('reviews'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = reviews[0];
const latest = reviews.slice(1, 4);

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-AU', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title="Home" currentPage="home">
  <!-- WebSite schema -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Dr. Samuel Rosehill",
    "url": "https://samrosehill.com",
    "description": "A clinical archive of dental research reviews and case notes by Dr. Samuel Rosehill.",
    "author": {
      "@type": "Person",
      "name": "Dr. Samuel Rosehill",
      "url": "https://samrosehill.com/about"
    }
  })} />

  <!-- Hero — asymmetric 7/5 grid -->
  <section class="hero">
    <div class="container grid-12">
      <div class="col-7 hero__content animate-in">
        <p class="label label--accent">A Clinical Archive</p>
        <h1>Reviews from the dental literature.</h1>
        <p class="hero__sub">
          Recent publications reviewed for clinical relevance by Dr. Samuel Rosehill.
        </p>
        <div class="hero__actions">
          <a href="/journal" class="btn btn--primary">Browse the archive</a>
          <a href="/about" class="btn btn--ghost">About the author</a>
        </div>
      </div>
      <div class="col-5 hero__aside animate-in animate-in--delay-2">
        <div class="hero__stat-card">
          <p class="hero__stat-label">Areas of Focus</p>
          <p class="hero__stat-value">Prosthodontics<br/>Digital Dentistry<br/>Implantology</p>
          <p class="hero__stat-sub">Shade matching · 3D printing · Soft tissue · Biomaterials</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Review — dark overlay card -->
  {featured && (
    <section class="section--toned">
      <div class="container">
        <p class="label" style="margin-bottom: var(--space-6);">Featured Review</p>
        <a href={`/journal/${featured.id}`} class="featured-review animate-in">
          <article class="card--featured">
            <p class="featured-review__label">{formatDate(featured.data.pubDate)}</p>
            <h2 class="featured-review__title">{featured.data.title}</h2>
            <p class="featured-review__desc">{featured.data.description}</p>
            <div class="featured-review__tags">
              {featured.data.tags.map((tag: string) => (
                <span class="chip chip--light">{tag}</span>
              ))}
            </div>
            <p class="featured-review__read">Read review &rarr;</p>
          </article>
        </a>
      </div>
    </section>
  )}

  <!-- More Reviews — card grid -->
  {latest.length > 0 && (
    <section>
      <div class="container">
        <div class="section-header">
          <h2>Recent additions</h2>
          <a href="/journal" class="section-link">Full archive &rarr;</a>
        </div>
        <div class="review-list review-list--grid">
          {latest.map((review, i) => (
            <a href={`/journal/${review.id}`} class={`review-card animate-in animate-in--delay-${i + 1}`}>
              <article class="card">
                <p class="review-card__date">{formatDate(review.data.pubDate)}</p>
                <h3 class="review-card__title">{review.data.title}</h3>
                <p class="review-card__description">{review.data.description}</p>
                <div class="review-card__tags">
                  {review.data.tags.map((tag: string) => (
                    <span class="chip">{tag}</span>
                  ))}
                </div>
              </article>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Base>

<style>
  .hero {
    padding: var(--space-24) 0 var(--space-20);
    align-items: center;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .hero__content .label {
    margin-bottom: 0;
  }

  .hero__content h1 {
    max-width: 18ch;
    line-height: 1.1;
  }

  .hero__sub {
    font-size: 1.0625rem;
    color: var(--on-surface-variant);
    line-height: 1.7;
    max-width: 48ch;
  }

  .hero__actions {
    display: flex;
    gap: var(--space-4);
    margin-top: var(--space-2);
  }

  .hero__aside {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero__stat-card {
    background: var(--surface-container-lowest);
    border: 1px solid var(--ghost-border);
    border-radius: 0.5rem;
    padding: var(--space-8) var(--space-6);
    box-shadow: var(--shadow-ambient);
    text-align: center;
    width: 100%;
    max-width: 280px;
  }

  .hero__stat-label {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--on-surface-variant);
    margin-bottom: var(--space-4);
  }

  .hero__stat-value {
    font-family: var(--font-headline);
    font-size: 1.375rem;
    color: var(--primary-dark);
    line-height: 1.3;
    margin-bottom: var(--space-3);
  }

  .hero__stat-sub {
    font-size: 0.8125rem;
    color: var(--on-surface-variant);
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-8);
  }

  .section-link {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--primary-dark);
  }

  .section-link:hover {
    text-decoration: none;
    opacity: 0.8;
  }

  .featured-review__tags {
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
    flex-wrap: wrap;
  }

  @media (max-width: 1024px) {
    .hero {
      padding: var(--space-16) 0 var(--space-12);
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: var(--space-12) 0 var(--space-8);
    }

    .hero__content h1 {
      max-width: 100%;
    }

    .hero__aside {
      justify-content: flex-start;
    }

    .hero__stat-card {
      text-align: left;
      max-width: 100%;
    }

    .hero__actions {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
