---
// import Loader from '../components/Loader.astro'; // TODO: revisit Cool S animation

interface Props {
  title: string;
  description?: string;
  currentPage?: string;
  ogImage?: string;
}

const {
  title,
  description = 'A clinical archive of dental research reviews and case notes by Dr. Samuel Rosehill.',
  currentPage = '',
  ogImage = '',
} = Astro.props;

const pageTitle = title === 'Home' ? 'Dr. Samuel Rosehill' : `${title} — Dr. Samuel Rosehill`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = ogImage ? new URL(ogImage, Astro.site).href : '';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Dr. Samuel Rosehill" />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content={ogImageUrl ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

    <!-- Structured data for GEO — Person (site-wide identity) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "@id": "https://orcid.org/0009-0008-0466-3625",
      "identifier": "https://orcid.org/0009-0008-0466-3625",
      "name": "Dr. Samuel Rosehill",
      "givenName": "Samuel",
      "familyName": "Rosehill",
      "honorificPrefix": "Dr.",
      "jobTitle": "Dentist",
      "description": "A clinical archive of dental research reviews and case notes by Dr. Samuel Rosehill.",
      "url": "https://samrosehill.com",
      "worksFor": {
        "@type": "Dentist",
        "name": "Ethical Dental and Orthodontics",
        "url": "https://www.ethical.dental",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Coffs Harbour",
          "addressRegion": "NSW",
          "addressCountry": "AU"
        }
      },
      "alumniOf": [
        { "@type": "CollegeOrUniversity", "name": "University of Queensland", "url": "https://www.uq.edu.au" },
        { "@type": "CollegeOrUniversity", "name": "King's College London", "url": "https://www.kcl.ac.uk" }
      ],
      "knowsAbout": [
        "Prosthodontics",
        "Dental Implantology",
        "Digital Dentistry",
        "Shade Matching",
        "3D Printing in Dentistry",
        "Guided Implant Surgery",
        "Biomaterials"
      ],
      "sameAs": [
        "https://www.linkedin.com/in/sam-rosehill-74905755/",
        "https://www.ethical.dental/about-us/dr-sam-rosehill",
        "https://samuelrosehill.substack.com",
        "https://orcid.org/0009-0008-0466-3625",
        "https://www.researchgate.net/profile/Samuel-Rosehill-2"
      ]
    })} />

    <!-- Page-specific structured data injected by child pages -->
    <slot name="head" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon.svg" />
  </head>
  <body>
    <!-- Skip to main content (accessibility) -->
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <!-- Navigation — glassmorphic sticky with ghost border -->
    <nav class="nav">
      <div class="container nav__inner">
        <a href="/" class="nav__brand">dr<span class="nav__brand-sep">/</span>samuel<span class="nav__brand-sep">/</span><span class="nav__brand-last">rosehill</span><span class="nav__brand-cursor">_</span></a>
        <ul class="nav__links">
          <li><a href="/" aria-current={currentPage === 'home' ? 'page' : undefined}>Home</a></li>
          <li><a href="/journal" aria-current={currentPage === 'journal' ? 'page' : undefined}>Journal</a></li>
          <li><a href="/projects" aria-current={currentPage === 'projects' ? 'page' : undefined}>Projects</a></li>
          <li><a href="/about" aria-current={currentPage === 'about' ? 'page' : undefined}>About</a></li>
        </ul>
        <button class="nav__menu-btn" aria-label="Open navigation menu" aria-expanded="false" aria-controls="nav-mobile-menu" id="nav-menu-btn">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </nav>

    <!-- Mobile menu overlay -->
    <div class="nav__mobile-menu" id="nav-mobile-menu" aria-hidden="true" role="dialog" aria-label="Navigation menu">
      <button class="nav__mobile-close" id="nav-mobile-close" aria-label="Close navigation menu">&times;</button>
      <ul class="nav__mobile-links">
        <li><a href="/" aria-current={currentPage === 'home' ? 'page' : undefined}>Home</a></li>
        <li><a href="/journal" aria-current={currentPage === 'journal' ? 'page' : undefined}>Journal</a></li>
        <li><a href="/projects" aria-current={currentPage === 'projects' ? 'page' : undefined}>Projects</a></li>
        <li><a href="/about" aria-current={currentPage === 'about' ? 'page' : undefined}>About</a></li>
        <li><a href="/privacy">Privacy</a></li>
      </ul>
    </div>

    <main id="main-content">
      <slot />
    </main>

    <!-- Footer — endnote -->
    <footer class="footer" role="contentinfo">
      <div class="container">
        <div class="footer__endnote">
          <span class="footer__number" aria-hidden="true">1</span>
          <p class="footer__text">
            A clinical archive of dental research reviews and case notes. This collection includes
            a <a href="/journal">journal</a> of research reviews,
            ongoing <a href="/projects">projects</a>,
            and notes <a href="/about">about the author</a>.
            Further work appears at <a href="https://www.ethical.dental" target="_blank" rel="noopener">Ethical Dental</a>,
            <a href="https://www.linkedin.com/in/sam-rosehill-74905755/" target="_blank" rel="noopener">LinkedIn</a>,
            <a href="https://samuelrosehill.substack.com" target="_blank" rel="noopener">Substack</a>,
            and <a href="https://www.researchgate.net/profile/Samuel-Rosehill-2" target="_blank" rel="noopener">ResearchGate</a>.
            See also: <a href="/">home</a>, <a href="/privacy">privacy</a>.
          </p>
        </div>
        <p class="footer__brand">dr/samuel/<span class="footer__brand-last">rosehill</span><span class="footer__brand-cursor">_</span></p>
        <p class="footer__meta">Coffs Harbour, NSW &middot; &copy; {new Date().getFullYear()} Dr. Samuel Rosehill</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<script>
  // Mobile navigation toggle
  const menuBtn = document.getElementById('nav-menu-btn');
  const mobileMenu = document.getElementById('nav-mobile-menu');
  const closeBtn = document.getElementById('nav-mobile-close');

  function openMenu() {
    mobileMenu?.classList.add('is-open');
    menuBtn?.setAttribute('aria-expanded', 'true');
    mobileMenu?.removeAttribute('aria-hidden');
    document.body.style.overflow = 'hidden';
    closeBtn?.focus();
  }

  function closeMenu() {
    mobileMenu?.classList.remove('is-open');
    menuBtn?.setAttribute('aria-expanded', 'false');
    mobileMenu?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    menuBtn?.focus();
  }

  menuBtn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && mobileMenu?.classList.contains('is-open')) {
      closeMenu();
    }
  });

  // Close when a nav link is clicked
  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });
</script>
