---
// import Loader from '../components/Loader.astro'; // TODO: revisit Cool S animation

interface Props {
  title: string;
  description?: string;
  currentPage?: string;
  ogImage?: string;
}

const {
  title,
  description = 'A clinical archive of dental research reviews and case notes by Dr. Samuel Rosehill.',
  currentPage = '',
  ogImage = '',
} = Astro.props;

const pageTitle = title === 'Home' ? 'Dr. Samuel Rosehill' : `${title} — Dr. Samuel Rosehill`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = ogImage ? new URL(ogImage, Astro.site).href : '';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Dr. Samuel Rosehill" />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content={ogImageUrl ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

    <!-- Structured data for GEO — Person (site-wide identity) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Dr. Samuel Rosehill",
      "givenName": "Samuel",
      "familyName": "Rosehill",
      "honorificPrefix": "Dr.",
      "jobTitle": "Dentist",
      "description": "A clinical archive of dental research reviews and case notes by Dr. Samuel Rosehill.",
      "url": "https://samrosehill.com",
      "worksFor": {
        "@type": "Dentist",
        "name": "Ethical Dental and Orthodontics",
        "url": "https://www.ethical.dental",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Coffs Harbour",
          "addressRegion": "NSW",
          "addressCountry": "AU"
        }
      },
      "alumniOf": [
        { "@type": "CollegeOrUniversity", "name": "University of Queensland", "url": "https://www.uq.edu.au" },
        { "@type": "CollegeOrUniversity", "name": "King's College London", "url": "https://www.kcl.ac.uk" }
      ],
      "knowsAbout": [
        "Prosthodontics",
        "Dental Implantology",
        "Digital Dentistry",
        "Shade Matching",
        "3D Printing in Dentistry",
        "Guided Implant Surgery",
        "Biomaterials"
      ],
      "sameAs": [
        "https://www.linkedin.com/in/sam-rosehill-74905755/",
        "https://www.ethical.dental/about-us/dr-sam-rosehill"
      ]
    })} />

    <!-- Page-specific structured data injected by child pages -->
    <slot name="head" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <!-- TODO: Cool S loading animation (revisit later) -->

    <!-- Navigation — glassmorphic sticky with ghost border -->
    <nav class="nav">
      <div class="container nav__inner">
        <a href="/" class="nav__brand">Dr. Samuel Rosehill</a>
        <ul class="nav__links">
          <li><a href="/" aria-current={currentPage === 'home' ? 'page' : undefined}>Home</a></li>
          <li><a href="/reviews" aria-current={currentPage === 'reviews' ? 'page' : undefined}>Journal</a></li>
          <li><a href="/cases" aria-current={currentPage === 'cases' ? 'page' : undefined}>Projects</a></li>
          <li><a href="/about" aria-current={currentPage === 'about' ? 'page' : undefined}>About</a></li>
        </ul>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <!-- Footer — multi-column editorial -->
    <footer class="footer">
      <div class="container">
        <div class="footer__grid">
          <div>
            <div class="footer__brand">Dr. Samuel Rosehill</div>
            <p class="footer__text">
              A clinical archive of dental research reviews and case notes
              from a prosthodontic enthusiast in Coffs Harbour, NSW.
            </p>
          </div>
          <div>
            <p class="footer__col-title">Navigate</p>
            <ul class="footer__link-list">
              <li><a href="/">Home</a></li>
              <li><a href="/reviews">Journal</a></li>
              <li><a href="/cases">Projects</a></li>
              <li><a href="/about">About</a></li>
            </ul>
          </div>
          <div>
            <p class="footer__col-title">Elsewhere</p>
            <ul class="footer__link-list">
              <li><a href="https://www.ethical.dental" target="_blank" rel="noopener">Ethical Dental</a></li>
              <li><a href="https://www.linkedin.com/in/sam-rosehill-74905755/" target="_blank" rel="noopener">LinkedIn</a></li>
            </ul>
          </div>
        </div>
        <div class="footer__bottom">
          &copy; {new Date().getFullYear()} Dr. Samuel Rosehill. Built with care in Coffs Harbour.
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
