---
/**
 * Animated loading screen — draws the "Cool S" symbol (14 line segments)
 *
 * Geometry (viewBox 0 0 100 220):
 *   Columns at x=20, x=50, x=80  (spacing 30)
 *   Upper row: y=25 → y=70       (length 45)
 *   Gap:       y=70 → y=120      (50 units — wide enough for steep diagonals)
 *   Lower row: y=120 → y=165     (length 45)
 *   Top apex:  (50, 5)
 *   Bottom apex: (50, 185)
 *
 *   4 diagonals bridge the gap with a weave (over/under) effect:
 *     ↘ Left→Center  (20,70)→(50,120)   — drawn OVER at left crossing
 *     ↙ Right→Center (80,70)→(50,120)   — drawn OVER at right crossing
 *     ↙ Center→Left  (50,70)→(20,120)   — BROKEN at left crossing (under)
 *     ↘ Center→Right (50,70)→(80,120)   — BROKEN at right crossing (under)
 *
 * Animation: verticals → diagonals (over then under) → caps → fade out
 */
---

<div class="loader" id="page-loader" aria-hidden="true">
  <svg
    class="loader__svg"
    viewBox="0 0 100 220"
    fill="none"
    stroke-linecap="round"
    stroke-linejoin="round"
    xmlns="http://www.w3.org/2000/svg"
  >
    <!-- Phase 1: Six vertical lines (two rows of three) -->
    <!-- Upper row -->
    <line class="draw v" x1="20" y1="25" x2="20" y2="70"  style="--len:45;--d:0s" />
    <line class="draw v" x1="50" y1="25" x2="50" y2="70"  style="--len:45;--d:0.08s" />
    <line class="draw v" x1="80" y1="25" x2="80" y2="70"  style="--len:45;--d:0.04s" />
    <!-- Lower row -->
    <line class="draw v" x1="20" y1="120" x2="20" y2="165" style="--len:45;--d:0.12s" />
    <line class="draw v" x1="50" y1="120" x2="50" y2="165" style="--len:45;--d:0.2s" />
    <line class="draw v" x1="80" y1="120" x2="80" y2="165" style="--len:45;--d:0.16s" />

    <!-- Phase 2a: "Over" diagonals (drawn complete) -->
    <!-- ↘ Left→Center (over at left crossing ~35,95) -->
    <line class="draw c" x1="20" y1="70" x2="50" y2="120" style="--len:58;--d:0.5s" />
    <!-- ↙ Right→Center (over at right crossing ~65,95) -->
    <line class="draw c" x1="80" y1="70" x2="50" y2="120" style="--len:58;--d:0.6s" />

    <!-- Phase 2b: "Under" diagonals (broken at crossing for weave) -->
    <!-- ↙ Center→Left: breaks at left crossing -->
    <line class="draw c" x1="50" y1="70" x2="41" y2="85"  style="--len:18;--d:0.7s" />
    <line class="draw c" x1="29" y1="105" x2="20" y2="120" style="--len:18;--d:0.8s" />
    <!-- ↘ Center→Right: breaks at right crossing -->
    <line class="draw c" x1="50" y1="70" x2="59" y2="85"  style="--len:18;--d:0.75s" />
    <line class="draw c" x1="71" y1="105" x2="80" y2="120" style="--len:18;--d:0.85s" />

    <!-- Phase 3: Top and bottom caps -->
    <line class="draw cap" x1="20" y1="25" x2="50" y2="5"  style="--len:36;--d:1.1s" />
    <line class="draw cap" x1="80" y1="25" x2="50" y2="5"  style="--len:36;--d:1.15s" />
    <line class="draw cap" x1="20" y1="165" x2="50" y2="185" style="--len:36;--d:1.2s" />
    <line class="draw cap" x1="80" y1="165" x2="50" y2="185" style="--len:36;--d:1.25s" />
  </svg>
</div>

<style>
  .loader {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--surface, #f9f9fb);
    opacity: 1;
    transition: opacity 0.5s ease 2.0s;
    pointer-events: none;
  }

  .loader.done {
    opacity: 0;
  }

  .loader__svg {
    width: 60px;
    height: auto;
    stroke: var(--primary, #004747);
    stroke-width: 4.5;
  }

  /* Stroke-draw animation using CSS custom properties */
  .draw {
    stroke-dasharray: var(--len);
    stroke-dashoffset: var(--len);
    animation: draw-line 0.4s ease-out forwards;
    animation-delay: var(--d);
  }

  .draw.v {
    animation-duration: 0.35s;
  }

  .draw.c {
    animation-duration: 0.3s;
    animation-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
  }

  .draw.cap {
    animation-duration: 0.25s;
    animation-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
  }

  @keyframes draw-line {
    to {
      stroke-dashoffset: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .draw {
      animation: none;
      stroke-dashoffset: 0;
    }
    .loader {
      transition-delay: 0.2s;
    }
  }
</style>

<script>
  const loader = document.getElementById('page-loader');
  if (loader) {
    setTimeout(() => {
      loader.classList.add('done');
    }, 2000);

    setTimeout(() => {
      loader.remove();
    }, 2600);
  }
</script>
